  "controls": {
    "stickDeadzone": 0.15,
    "dashDurationMs": 180,
    "dashCooldownMs": 600,
    "dashIFramesMs": 120,
    "dashSpeedMultiplier": 2.75,
    "meleeArcDeg": 120,
    "meleeRangePx": 48,
    "meleeActiveMs": 80,
    "throwChargeMaxMs": 800,
    "recallHomingBoost": 0.08
