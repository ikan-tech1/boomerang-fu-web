{
  "$schema": "./schemas/balance.schema.json",
  "_meta": {
    "version": "0.1.0",
    "references": [
      "docs/reference/controls.md",
      "docs/reference/physics.md",
      "docs/reference/power-ups.md",
      "https://en.wikipedia.org/wiki/Boomerang_Fu",
      "Steam store page"
    ]
  },
  "controls": {
    "stickDeadzone": 0.15,
    "dashDurationMs": 180,
    "dashCooldownMs": 600,
    "dashIFramesMs": 120,
    "dashSpeedMultiplier": 2.75,
    "meleeArcDeg": 120,
    "meleeRangePx": 48,
    "meleeActiveMs": 80,
    "throwChargeMaxMs": 800,
    "recallHomingBoost": 0.08
  },
  "player": {
    "baseSpeed": 218,
    "acceleration": 1800,
    "friction": 1200,
    "radiusPx": 20,
    "mass": 1.0,
    "respawnDelayMs": 2000,
    "respawnIFramesMs": 1000
  },
  "boomerang": {
    "minThrowSpeed": 400,
    "maxThrowSpeed": 900,
    "spinRateDegPerSec": 720,
    "wallRestitution": 0.85,
    "returnHomingStrength": 0.13,
    "returnSpeed": 650,
    "pickupRadiusPx": 32,
    "maxBounces": 8,
    "dropFriction": 0.95,
    "selfHitOnReturn": true
  },
  "combat": {
    "oneHitKill": true,
    "hitstopMs": 50,
    "killKnockback": 300,
    "droppedBoomerangKill": true
  },
  "match": {
    "defaultRoundTimerSec": 120,
    "countdownSec": 3,
    "maxPlayers": 6,
    "maxPowerUpStack": 3,
    "powerUpSpawnIntervalSec": 8,
    "powerUpPickupRadiusPx": 28
  },
  "modes": {
    "freeForAll": {
      "friendlyFireDefault": false
    },
    "teams": {
      "teamCount": 2,
      "teamNames": ["Spicy", "Chill"]
    },
    "goldenBoomerang": {
      "moveSpeedMultiplier": 0.7,
      "killPoints": 3,
      "spawnDelaySec": 30
    },
    "hideAndSeek": {
      "hidePhaseSec": 30,
      "seekPhaseSec": 90
    }
  },
  "powerUps": {
    "shield": { "id": "shield", "name": "Shield", "maxUses": 1, "conflicts": [] },
    "fire": { "id": "fire", "name": "Fire", "maxUses": -1, "conflicts": ["ice"] },
    "ice": { "id": "ice", "name": "Ice", "maxUses": -1, "conflicts": ["fire"] },
    "explosive": { "id": "explosive", "name": "Explosive", "maxUses": 3, "conflicts": [] },
